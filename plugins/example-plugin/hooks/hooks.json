{
  "description": "example-plugin Hook — 演示 SessionStart 与 PostToolUse 的最小实现",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "python",
            "function": ".example-plugin_hook:hook_session_start",
            "timeout": 5,
            "enabled": true,
            "id": "11111111-1111-4111-8111-111111111111"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "python",
            "function": ".example-plugin_hook:hook_post_tool_use",
            "timeout": 5,
            "enabled": true,
            "id": "22222222-2222-4222-8222-222222222222"
          }
        ]
      }
    ]
  }
}
